{
  "name": "genart-live-viewer",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "A browser-based viewer for fxhash generative art stored on onchfs/IPFS, designed to outlive fxhash itself. Rebuild of _legacy/onchfs-viewer.",
  "scripts": {
    "dev": "vite",
    "index": "node scripts/build-index.mjs",
    "build": "tsc -b && vite build && vite build --config vite.sw.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "idb-keyval": "^6.2.1",
    "onchfs": "^0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  }
}
